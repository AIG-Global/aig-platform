# Generate these once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Required by the Web Push spec — push services use this to contact you
# if your server is misbehaving (e.g. sending too many pushes). A real
# email you monitor, not a placeholder.
VAPID_CONTACT_EMAIL=mailto:you@example.com

PORT=3001

# Protects /api/usage-map (the anonymous usage dashboard data). Generate
# a real random value, e.g.: openssl rand -hex 32
# This is a shared-secret stand-in for real auth — fine for a solo admin
# checking a dashboard, not fine as your only protection once more than
# one person needs access or this handles anything more sensitive.
ADMIN_TOKEN=
