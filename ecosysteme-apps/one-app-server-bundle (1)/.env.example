# ONE backend — environment configuration
#
# Copy this file to .env and fill in real values, or export these
# as real environment variables in your deployment. None of these
# are required for the backend to start — without them, payment
# creation falls back to a clearly-labelled placeholder mode so the
# rest of the system (admin dashboard, analytics, etc.) keeps working.

# ---------------- Server ----------------
PORT=8090
# The public URL this server is reachable at — used to build the
# NOWPayments success_url / cancel_url / ipn_callback_url. Must be a
# real, internet-reachable HTTPS URL in production (NOWPayments
# cannot call back to localhost).
PUBLIC_BASE_URL=https://your-domain.example.com

# ---------------- NOWPayments ----------------
# From your NOWPayments dashboard -> Settings -> API keys.
NOWPAYMENTS_API_KEY=

# From your NOWPayments dashboard -> Payment Settings -> IPN secret.
# Required to verify that webhook calls genuinely came from NOWPayments.
NOWPAYMENTS_IPN_SECRET=

# Set to "true" to point at NOWPayments' sandbox environment while
# testing the full pay -> webhook -> upgrade flow before going live.
NOWPAYMENTS_SANDBOX=true
