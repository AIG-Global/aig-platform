{
  "name": "api",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "scripts": {
    "start": "node dist/main.js",
    "dev": "node node_modules/typescript/bin/tsc --skipLibCheck -p tsconfig.json && node dist/main.js",
    "build": "node node_modules/typescript/bin/tsc --skipLibCheck -p tsconfig.json",
    "build:watch": "node node_modules/typescript/bin/tsc --skipLibCheck -p tsconfig.json --watch",
    "test": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --testPathPatterns=e2e.test --forceExit",
    "test:unit": "node --experimental-vm-modules node_modules/jest-cli/bin/jest.js --testPathPatterns=unit --forceExit"
  },
  "dependencies": {
    "@aig/identity": "workspace:*",
    "@aig/organization-management": "workspace:*",
    "@aig/user-management": "workspace:*",
    "@anthropic-ai/sdk": "^0.110.0",
    "@nestjs/common": "^10.3.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.22",
    "@prisma/client": "^5.22.0",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^2.4.3",
    "openai": "^6.45.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.0.0",
    "jest": "^30.4.2",
    "prisma": "^5.22.0",
    "ts-jest": "^29.4.11",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
