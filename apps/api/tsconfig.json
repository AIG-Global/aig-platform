{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "baseUrl": ".",
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "incremental": false,
    "noEmitOnError": false,
    "strict": false,
    "lib": ["ES2020", "DOM"],
    "target": "ES2020",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/activity/**",
    "src/ai/**",
    "src/chat/**",
    "src/commissions/**",
    "src/generals/**",
    "src/missions/**",
    "src/mission/**",
    "src/progress/**",
    "src/projects/**",
    "src/tasks/**",
    "src/workspace/**",
    "src/wdm/**",
    "src/analytics/**",
    "src/mailchimp/**",
    "src/payment/**"
  ],
  "ts-node": {
    "transpileOnly": true,
    "compilerOptions": {
      "skipLibCheck": true
    }
  }
}
