// AIGINVEST Ecosystem - Complete Prisma Schema
// Version: 1.0
// Purpose: Single source of truth for all AIG data models
// Generated: 2026-07-07

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================================
// AUTHENTICATION & USERS
// ============================================================================

model User {
  id                    String      @id @default(cuid())
  email                 String      @unique
  password_hash         String
  first_name            String?
  last_name             String?
  avatar_url            String?
  bio                   String?
  phone_number          String?
  date_of_birth         DateTime?
  nationality           String?
  
  // Account status
  status                UserStatus  @default(ACTIVE)
  email_verified        Boolean     @default(false)
  email_verified_at     DateTime?
  last_login            DateTime?
  created_at            DateTime    @default(now())
  updated_at            DateTime    @updatedAt
  deleted_at            DateTime?
  
  // Foreign keys
  primary_org_id        String?
  primary_org           Organization? @relation("users_primary_org", fields: [primary_org_id], references: [id])
  
  // Relations
  accounts              Account[]
  memberships           Membership[]
  employees             Employee[]
  addresses             Address[]
  auth_tokens           AuthToken[]
  refresh_tokens        RefreshToken[]
  diana_conversations   DianConversation[]
  diana_personal_memory DianaPersonalMemory[]
  diana_documents       DianaDocument[]
  commissions           Commission[]
  investments           Investment[]
  wallet_transactions   WalletTransaction[]
  
  @@index([email])
  @@index([primary_org_id])
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  BANNED
  DELETED
}

model AuthToken {
  id          String   @id @default(cuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token       String   @unique
  type        TokenType
  expires_at  DateTime
  created_at  DateTime @default(now())
  
  @@index([user_id])
  @@index([token])
}

model RefreshToken {
  id          String   @id @default(cuid())
  user_id     String
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  token       String   @unique
  expires_at  DateTime
  revoked_at  DateTime?
  created_at  DateTime @default(now())
  
  @@index([user_id])
}

enum TokenType {
  ACCESS
  REFRESH
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ============================================================================
// ORGANIZATION & HIERARCHY
// ============================================================================

model Organization {
  id                String          @id @default(cuid())
  name              String
  slug              String          @unique
  description       String?
  logo_url          String?
  website           String?
  industry          String?
  company_size      String?
  vat_id            String?
  registration_num  String?
  
  // Business info
  founded_at        DateTime?
  status            OrgStatus       @default(ACTIVE)
  created_at        DateTime        @default(now())
  updated_at        DateTime        @updatedAt
  
  // Relations
  users             User[]          @relation("users_primary_org")
  departments       Department[]
  teams             Team[]
  employees         Employee[]
  memberships       Membership[]
  addresses         Address[]
  wallets           Wallet[]
  ai_instances      AIInstance[]
  
  @@index([slug])
  @@index([status])
}

enum OrgStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model Department {
  id          String      @id @default(cuid())
  org_id      String
  org         Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  name        String
  slug        String
  description String?
  
  // Hierarchy
  parent_id   String?
  parent      Department? @relation("parent_children", fields: [parent_id], references: [id], onDelete: SetNull)
  children    Department[] @relation("parent_children")
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  teams       Team[]
  employees   Employee[]
  ai_instances AIInstance[]
  
  @@unique([org_id, slug])
  @@index([org_id])
  @@index([parent_id])
}

model Team {
  id          String      @id @default(cuid())
  org_id      String
  org         Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  dept_id     String?
  dept        Department? @relation(fields: [dept_id], references: [id], onDelete: SetNull)
  
  name        String
  slug        String
  description String?
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  employees   Employee[]
  
  @@unique([org_id, slug])
  @@index([org_id])
  @@index([dept_id])
}

model Employee {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org_id      String
  org         Organization @relation(fields: [org_id], references: [id], onDelete: Cascade)
  team_id     String?
  team        Team?       @relation(fields: [team_id], references: [id], onDelete: SetNull)
  dept_id     String?
  dept        Department? @relation(fields: [dept_id], references: [id], onDelete: SetNull)
  
  title       String
  role        EmployeeRole
  status      EmployeeStatus @default(ACTIVE)
  joined_at   DateTime    @default(now())
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  @@unique([user_id, org_id])
  @@index([user_id])
  @@index([org_id])
  @@index([team_id])
}

enum EmployeeRole {
  ADMIN
  MANAGER
  EMPLOYEE
  CONTRACTOR
  VIEWER
}

enum EmployeeStatus {
  ACTIVE
  INACTIVE
  ON_LEAVE
  TERMINATED
}

// ============================================================================
// MEMBERSHIP & SUBSCRIPTIONS
// ============================================================================

model Membership {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org_id      String?
  org         Organization? @relation(fields: [org_id], references: [id], onDelete: SetNull)
  
  tier        MembershipTier
  status      SubscriptionStatus @default(ACTIVE)
  
  // Billing
  billing_cycle BillingCycle
  price_eur   Int           // Stored in cents (€1.00 = 100)
  next_billing DateTime
  auto_renew  Boolean     @default(true)
  
  // Period
  started_at  DateTime    @default(now())
  expires_at  DateTime?
  renewed_at  DateTime?
  cancelled_at DateTime?
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  app_subscriptions AppSubscription[]
  
  @@unique([user_id])
  @@index([tier])
  @@index([status])
}

enum MembershipTier {
  FREE
  STARTER
  PROFESSIONAL
  BUSINESS
  ENTERPRISE
}

enum BillingCycle {
  MONTHLY
  ANNUAL
}

enum SubscriptionStatus {
  ACTIVE
  PAUSED
  CANCELLED
  EXPIRED
  PENDING
}

// ============================================================================
// APPS & FEATURES
// ============================================================================

model AIApp {
  id          String      @id @default(cuid())
  name        String      @unique
  slug        String      @unique
  description String
  icon_url    String?
  color       String?
  
  // Version & status
  version     String      @default("1.0.0")
  status      AppStatus   @default(ACTIVE)
  
  // Availability
  min_tier    MembershipTier
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  subscriptions AppSubscription[]
  features    AppFeature[]
  
  @@index([min_tier])
}

enum AppStatus {
  ACTIVE
  BETA
  DEPRECATED
  DISABLED
}

model AppFeature {
  id          String      @id @default(cuid())
  app_id      String
  app         AIApp       @relation(fields: [app_id], references: [id], onDelete: Cascade)
  
  name        String
  description String?
  
  @@index([app_id])
}

model AppSubscription {
  id          String      @id @default(cuid())
  membership_id String
  membership  Membership  @relation(fields: [membership_id], references: [id], onDelete: Cascade)
  app_id      String
  app         AIApp       @relation(fields: [app_id], references: [id], onDelete: Cascade)
  
  status      SubStatus   @default(ACTIVE)
  subscribed_at DateTime   @default(now())
  unsubscribed_at DateTime?
  
  @@unique([membership_id, app_id])
  @@index([membership_id])
  @@index([app_id])
}

enum SubStatus {
  ACTIVE
  INACTIVE
  CANCELLED
}

// ============================================================================
// ACCOUNTS & WALLETS (TWO-ACCOUNT SYSTEM)
// ============================================================================

model Account {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  type        AccountType
  status      AccountStatus @default(ACTIVE)
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  wallets     Wallet[]
  
  @@unique([user_id, type])
  @@index([user_id])
}

enum AccountType {
  CASH_ACCOUNT          // EUR-based, fiat
  AIG_CASH_ACCOUNT      // Ecosystem tokens (AIG$)
}

enum AccountStatus {
  ACTIVE
  FROZEN
  SUSPENDED
  CLOSED
}

model Wallet {
  id          String      @id @default(cuid())
  account_id  String
  account     Account     @relation(fields: [account_id], references: [id], onDelete: Cascade)
  org_id      String?
  org         Organization? @relation(fields: [org_id], references: [id], onDelete: SetNull)
  
  balance     BigInt      @default(0)  // In cents (EUR) or satoshis (AIG$)
  currency    Currency
  
  last_updated DateTime   @updatedAt
  
  // Relations
  transactions WalletTransaction[]
  
  @@unique([account_id])
  @@index([org_id])
}

enum Currency {
  EUR
  AIG
}

model WalletTransaction {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id])
  wallet_id   String
  wallet      Wallet      @relation(fields: [wallet_id], references: [id], onDelete: Cascade)
  
  type        TransactionType
  amount      BigInt        // In cents (EUR) or satoshis (AIG$)
  currency    Currency
  balance_after BigInt
  
  description String?
  reference   String?       // Commission ID, Investment ID, etc.
  
  status      TransactionStatus @default(COMPLETED)
  created_at  DateTime    @default(now())
  
  @@index([user_id])
  @@index([wallet_id])
  @@index([created_at])
}

enum TransactionType {
  DEPOSIT           // Money in
  WITHDRAWAL        // Money out
  COMMISSION        // Earned commission
  MEMBERSHIP_FEE    // Paid membership
  INVESTMENT        // Investment purchase
  RETURN            // Investment return
  CONVERSION        // EUR <-> AIG$
  CORRECTION        // Admin correction
  BONUS             // Reward/bonus
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  REVERSED
}

// ============================================================================
// COMMISSIONS & EARNINGS
// ============================================================================

model Commission {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  source_type CommissionSource
  source_id   String        // Referral ID, Order ID, etc.
  
  tier        Int           // 1-10 (affiliate level)
  level_percent Float        // e.g., 26.0 for L1
  
  amount_eur  BigInt        // In cents
  status      CommissionStatus @default(PENDING)
  
  earned_at   DateTime    @default(now())
  paid_at     DateTime?
  created_at  DateTime    @default(now())
  
  // Relations
  payout      CommissionPayout?
  
  @@index([user_id])
  @@index([source_type, source_id])
  @@index([status])
  @@index([tier])
}

enum CommissionSource {
  REFERRAL        // Direct member referral
  WDM_ORDER       // Marketplace order
  INVESTMENT      // Investment product commission
  MEMBERSHIP      // Membership referral
}

enum CommissionStatus {
  PENDING
  APPROVED
  PAID
  CANCELLED
  DISPUTED
}

model CommissionPayout {
  id          String      @id @default(cuid())
  commission_id String
  commission  Commission  @relation(fields: [commission_id], references: [id], onDelete: Cascade)
  
  payout_period DateTime
  amount_eur  BigInt        // 80% to EUR Cash Account
  amount_aig  BigInt        // 20% to AIG$ Account
  
  status      PayoutStatus @default(PENDING)
  paid_at     DateTime?
  created_at  DateTime    @default(now())
  
  @@unique([commission_id])
  @@index([payout_period])
}

enum PayoutStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  CANCELLED
}

model CommissionRule {
  id          String      @id @default(cuid())
  tier        MembershipTier
  level       Int           // 1-10 (affiliate level)
  percent     Float
  created_at  DateTime    @default(now())
  
  @@unique([tier, level])
  @@index([tier])
}

// ============================================================================
// INVESTMENTS & PORTFOLIO
// ============================================================================

model Investment {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  product_type InvestmentProduct
  amount_eur  BigInt        // In cents
  currency_used Currency
  
  lock_period Int?          // Months (null = liquid)
  expected_roi Float?
  
  started_at  DateTime    @default(now())
  maturity_at DateTime?
  returned_at DateTime?
  
  status      InvestmentStatus @default(ACTIVE)
  created_at  DateTime    @default(now())
  
  // Relations
  returns     InvestmentReturn[]
  
  @@index([user_id])
  @@index([product_type])
  @@index([status])
  @@index([maturity_at])
}

enum InvestmentProduct {
  CRYPTO_MARKET
  TAGMARKETS
  AIG_PHONE_SHARES
  MANAGED_3Y
  MANAGED_5Y
  MANAGED_7Y
  MANAGED_10Y
}

enum InvestmentStatus {
  ACTIVE
  MATURE
  RETURNED
  CANCELLED
  LIQUIDATED
}

model InvestmentReturn {
  id          String      @id @default(cuid())
  investment_id String
  investment  Investment  @relation(fields: [investment_id], references: [id], onDelete: Cascade)
  
  amount_eur  BigInt        // In cents
  amount_eur_80pct BigInt   // 80% to EUR Cash Account
  amount_aig_20pct BigInt   // 20% to AIG$ Account
  
  return_date DateTime    @default(now())
  created_at  DateTime    @default(now())
  
  @@index([investment_id])
}

// ============================================================================
// WDM MARKETPLACE
// ============================================================================

model WDMProduct {
  id          String      @id @default(cuid())
  name        String
  slug        String
  description String?
  price_eur   BigInt        // In cents
  
  category    WDMCategory
  
  seller_id   String        // Seller profile (external or User ID)
  status      ProductStatus @default(ACTIVE)
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  orders      WDMOrder[]
  reviews     WDMReview[]
  
  @@index([category])
  @@index([seller_id])
  @@index([status])
}

enum WDMCategory {
  LUXURY_VEHICLES
  ELECTRONICS
  TRAVEL
  REAL_ESTATE
  BUSINESS_SERVICES
  INVESTMENTS
  SOFTWARE_TOOLS
  EXPERIENCES
}

enum ProductStatus {
  ACTIVE
  INACTIVE
  DELISTED
  ARCHIVED
}

model WDMOrder {
  id          String      @id @default(cuid())
  product_id  String
  product     WDMProduct  @relation(fields: [product_id], references: [id])
  
  buyer_id    String        // Could be User ID or external
  quantity    Int
  price_eur   BigInt        // In cents
  commission_percent Float
  commission_eur BigInt    // Total commission to redistribute
  
  status      OrderStatus @default(PENDING)
  created_at  DateTime    @default(now())
  completed_at DateTime?
  
  // Relations
  items       WDMOrderItem[]
  reviews     WDMReview[]
  commission_redistribution WDMCommissionRedistribution[]
  
  @@index([product_id])
  @@index([buyer_id])
  @@index([status])
}

enum OrderStatus {
  PENDING
  CONFIRMED
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

model WDMOrderItem {
  id          String      @id @default(cuid())
  order_id    String
  order       WDMOrder    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  
  product_id  String
  quantity    Int
  unit_price  BigInt      // In cents
  total_price BigInt      // In cents
  
  @@index([order_id])
}

model WDMReview {
  id          String      @id @default(cuid())
  product_id  String
  product     WDMProduct  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  order_id    String
  order       WDMOrder    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  
  rating      Int           // 1-5
  title       String
  comment     String?
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  @@index([product_id])
}

model WDMCommissionRedistribution {
  id          String      @id @default(cuid())
  order_id    String
  order       WDMOrder    @relation(fields: [order_id], references: [id], onDelete: Cascade)
  
  affiliate_id String      // Member who gets commission
  level       Int           // 1-10
  amount_eur  BigInt        // In cents
  
  status      PayoutStatus @default(PENDING)
  created_at  DateTime    @default(now())
  
  @@index([order_id])
  @@index([affiliate_id])
}

// ============================================================================
// AI & DIANA
// ============================================================================

model AIInstance {
  id          String      @id @default(cuid())
  org_id      String?
  org         Organization? @relation(fields: [org_id], references: [id], onDelete: Cascade)
  dept_id     String?
  dept        Department? @relation(fields: [dept_id], references: [id], onDelete: SetNull)
  
  name        String
  description String?
  ai_type     AIType
  
  status      AIStatus    @default(ACTIVE)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  conversations DianConversation[]
  memory      DianaCompanyMemory[]
  
  @@index([org_id])
  @@index([dept_id])
}

enum AIType {
  MASTER_AI          // Organization-level
  DEPARTMENT_AI      // Department-level
  AUTONOMOUS_BOT     // Automated tasks
  USER_ASSISTANT     // Personal Diana
}

enum AIStatus {
  ACTIVE
  TRAINING
  INACTIVE
  ARCHIVED
}

model DianConversation {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ai_instance_id String?
  ai_instance AIInstance? @relation(fields: [ai_instance_id], references: [id], onDelete: SetNull)
  
  title       String?
  is_archived Boolean     @default(false)
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  messages    DianaMessage[]
  
  @@index([user_id])
  @@index([ai_instance_id])
}

model DianaMessage {
  id          String      @id @default(cuid())
  conversation_id String
  conversation DianConversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade)
  
  role        MessageRole
  content     String
  
  metadata    Json?
  created_at  DateTime    @default(now())
  
  @@index([conversation_id])
}

enum MessageRole {
  USER
  ASSISTANT
}

model DianaPersonalMemory {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  conversation_id String?
  
  key_topics  String[]
  summary     String?
  embedding   String?     // Vector stored as JSON for search
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  @@index([user_id])
}

model DianaCompanyMemory {
  id          String      @id @default(cuid())
  ai_instance_id String
  ai_instance AIInstance @relation(fields: [ai_instance_id], references: [id], onDelete: Cascade)
  
  document_name String
  document_content String
  category    String?
  access_level AccessLevel
  
  embedding   String?     // Vector stored as JSON
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  @@index([ai_instance_id])
  @@index([category])
}

enum AccessLevel {
  PUBLIC
  INTERNAL
  RESTRICTED
}

model DianaDocument {
  id          String      @id @default(cuid())
  user_id     String
  user        User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org_id      String?
  
  filename    String
  file_path   String
  content_type String
  extracted_text String?
  embedding   String?     // Vector stored as JSON
  
  uploaded_at DateTime    @default(now())
  
  @@index([user_id])
  @@index([org_id])
}

model DianaPlatformMemory {
  id          String      @id @default(cuid())
  topic       String
  content     String
  category    String?
  priority    Int         @default(0)
  
  embedding   String?     // Vector stored as JSON
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  @@index([category])
  @@index([priority])
}

// ============================================================================
// EVENTS (EVENT-DRIVEN ARCHITECTURE)
// ============================================================================

model Event {
  id          String      @id @default(cuid())
  event_type  String
  aggregate_id String
  aggregate_type String
  
  payload     Json
  metadata    Json?
  
  created_at  DateTime    @default(now())
  
  @@index([event_type])
  @@index([aggregate_type])
  @@index([created_at])
}

model EventSubscription {
  id          String      @id @default(cuid())
  event_type  String
  handler     String        // Service/handler name
  
  is_active   Boolean     @default(true)
  created_at  DateTime    @default(now())
  
  @@unique([event_type, handler])
}

model EventLog {
  id          String      @id @default(cuid())
  event_id    String
  
  handler     String
  status      EventLogStatus
  error_msg   String?
  
  processed_at DateTime   @default(now())
  
  @@index([event_id])
  @@index([status])
}

enum EventLogStatus {
  PENDING
  SUCCESS
  FAILED
  RETRY
}

model DeadLetterEvent {
  id          String      @id @default(cuid())
  event_id    String
  
  event_type  String
  payload     Json
  
  error_msg   String?
  retry_count Int         @default(0)
  
  created_at  DateTime    @default(now())
  
  @@index([event_type])
}

// ============================================================================
// COMPETITION & GROWTH
// ============================================================================

model Competition {
  id          String      @id @default(cuid())
  name        String
  description String?
  comp_type   CompetitionType
  
  start_date  DateTime
  end_date    DateTime
  
  status      CompetitionStatus @default(ACTIVE)
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  entries     CompetitionEntry[]
  leaderboards Leaderboard[]
  
  @@index([comp_type])
  @@index([status])
}

enum CompetitionType {
  MONTHLY_TIER_RISE
  FAST_TRACKER
  QUARTERLY_RANKING
  ANNUAL_AWARDS
}

enum CompetitionStatus {
  UPCOMING
  ACTIVE
  CLOSED
  ARCHIVED
}

model CompetitionEntry {
  id          String      @id @default(cuid())
  competition_id String
  competition Competition @relation(fields: [competition_id], references: [id], onDelete: Cascade)
  
  user_id     String
  score       Int
  
  entered_at  DateTime    @default(now())
  
  @@unique([competition_id, user_id])
  @@index([competition_id])
}

model Leaderboard {
  id          String      @id @default(cuid())
  competition_id String
  competition Competition @relation(fields: [competition_id], references: [id], onDelete: Cascade)
  
  rank        Int
  user_id     String
  score       Int
  
  updated_at  DateTime    @updatedAt
  
  @@unique([competition_id, rank])
  @@index([competition_id])
}

model Analytics {
  id          String      @id @default(cuid())
  user_id     String?
  org_id      String?
  
  metric_type String
  metric_value Float
  
  period_date DateTime
  created_at  DateTime    @default(now())
  
  @@index([user_id])
  @@index([org_id])
  @@index([metric_type])
}

// ============================================================================
// MODULAR SYSTEM
// ============================================================================

model Module {
  id          String      @id @default(cuid())
  name        String      @unique
  version     String
  
  status      ModuleStatus @default(DEVELOPMENT)
  description String?
  
  created_at  DateTime    @default(now())
  updated_at  DateTime    @updatedAt
  
  // Relations
  config      ModuleConfig?
  
  @@index([status])
}

enum ModuleStatus {
  DEVELOPMENT
  RELEASE
  ADOPTION
  OPERATION
  UPGRADE
  DISABLE
  SUNSET
}

model ModuleConfig {
  id          String      @id @default(cuid())
  module_id   String
  module      Module      @relation(fields: [module_id], references: [id], onDelete: Cascade)
  
  config_key  String
  config_value String
  
  @@unique([module_id, config_key])
  @@index([module_id])
}

// ============================================================================
// PERMISSIONS & ROLES
// ============================================================================

model Role {
  id          String      @id @default(cuid())
  name        String      @unique
  description String?
  
  created_at  DateTime    @default(now())
  
  // Relations
  permissions RolePermission[]
  
  @@index([name])
}

model Permission {
  id          String      @id @default(cuid())
  resource    String
  action      String
  description String?
  
  @@unique([resource, action])
}

model RolePermission {
  id          String      @id @default(cuid())
  role_id     String
  role        Role        @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission_id String
  permission  Permission  @relation("permission", fields: [permission_id], references: [id], onDelete: Cascade)
  
  @@unique([role_id, permission_id])
  @@index([role_id])
}

// ============================================================================
// ADDRESSES & CONTACT
// ============================================================================

model Address {
  id          String      @id @default(cuid())
  user_id     String?
  user        User?       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  org_id      String?
  org         Organization? @relation(fields: [org_id], references: [id], onDelete: Cascade)
  
  address_type AddressType
  street      String
  city        String
  region      String
  postal_code String
  country     String
  
  is_default  Boolean     @default(false)
  created_at  DateTime    @default(now())
  
  @@index([user_id])
  @@index([org_id])
}

enum AddressType {
  HOME
  WORK
  BILLING
  SHIPPING
}

// ============================================================================
// EXCHANGE RATE & CURRENCY
// ============================================================================

model ExchangeRate {
  id          String      @id @default(cuid())
  from_currency Currency
  to_currency Currency
  rate        Float
  
  valid_from  DateTime    @default(now())
  valid_to    DateTime?
  
  @@unique([from_currency, to_currency, valid_from])
  @@index([valid_from])
}
