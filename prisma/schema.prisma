// ============================================================================
// GENERALS & MANAGEMENT POOL SYSTEM
// ============================================================================

// A General is a leader appointed to receive a share of the 20% management pool
model General {
  id                    String        @id @default(cuid())
  user_id               String        @unique
  user                  User          @relation(fields: [user_id], references: [id], onDelete: Cascade)

  // Who appointed this general (null = root / admin-appointed)
  appointed_by_id       String?
  appointed_by          General?      @relation("general_hierarchy", fields: [appointed_by_id], references: [id])
  appointees            General[]     @relation("general_hierarchy")

  // Pool allocation: percent of the 20% management pool they earn
  // e.g., allocated_percent = 10.0 means they earn 10% of the pool
  allocated_percent     Float         @default(0)    // Total % allocated TO this general
  distributed_percent   Float         @default(0)    // How much they've given away to sub-generals
  // effective_percent = allocated_percent - distributed_percent (computed in app)

  // String capacity: sum of all allocated percents in this general's lineage chain
  // Enforced at application level: no chain can exceed 20%
  string_root_id        String?       // ID of the root General of this string (null = self is root)
  string_root           General?      @relation("string_members", fields: [string_root_id], references: [id])
  string_members        General[]     @relation("string_members")

  status                GeneralStatus @default(ACTIVE)

  created_at            DateTime      @default(now())
  updated_at            DateTime      @updatedAt

  // Relations
  appointments_given    GeneralAppointment[] @relation("appointment_general_giver")
  appointments_received GeneralAppointment[] @relation("appointment_general_receiver")
  pool_earnings         PoolEarning[]

  @@index([user_id])
  @@index([appointed_by_id])
  @@index([string_root_id])
}

enum GeneralStatus {
  ACTIVE
  SUSPENDED
  REVOKED
}

// Records a "Sharing is Caring" appointment: a General sharing % with another user
model GeneralAppointment {
  id                    String              @id @default(cuid())

  // The General giving away part of their allocation
  giver_general_id      String
  giver_general         General             @relation("appointment_general_giver", fields: [giver_general_id], references: [id])
  giver_user_id         String
  giver_user            User                @relation("appointment_giver", fields: [giver_user_id], references: [id])

  // The user receiving the appointment (becomes a General upon acceptance)
  receiver_user_id      String
  receiver_user         User                @relation("appointment_receiver", fields: [receiver_user_id], references: [id])
  receiver_general_id   String?             // Set when they accept and General record is created
  receiver_general      General?            @relation("appointment_general_receiver", fields: [receiver_general_id], references: [id])

  percent_given         Float               // % of pool being shared
  
  status                AppointmentStatus   @default(PENDING_CONTRACT)
  
  // Revocation: giver requests, admin approves
  revoke_requested_at   DateTime?
  revoke_approved_at    DateTime?
  revoke_notes          String?

  created_at            DateTime            @default(now())
  updated_at            DateTime            @updatedAt

  // Contract must be signed by both parties
  contract              GeneralContract?

  @@index([giver_general_id])
  @@index([receiver_user_id])
  @@index([status])
}

enum AppointmentStatus {
  PENDING_CONTRACT      // Waiting for both parties to sign
  CONTRACT_SIGNED       // Both signed, active
  ACTIVE                // General receiving pool earnings
  REVOKE_REQUESTED      // Giver wants it back, awaiting admin
  REVOKED               // Admin approved revocation
  REJECTED              // Receiver declined
}

// AIG-Secure-Sign contract embedded in the system
model GeneralContract {
  id                    String            @id @default(cuid())
  appointment_id        String            @unique
  appointment           GeneralAppointment @relation(fields: [appointment_id], references: [id])

  // Document reference (AIG-Secure-Sign output)
  document_url          String?
  document_hash         String?           // SHA-256 for integrity verification
  secure_sign_ref       String?           // AIG-Secure-Sign internal reference

  // Signing timestamps
  giver_signed_at       DateTime?
  receiver_signed_at    DateTime?
  admin_reviewed_at     DateTime?
  admin_reviewer_id     String?

  // Contract terms snapshot
  percent_given         Float
  terms_snapshot        String            // JSON snapshot of terms at signing time

  status                ContractStatus    @default(DRAFT)

  created_at            DateTime          @default(now())
  updated_at            DateTime          @updatedAt

  @@index([appointment_id])
  @@index([status])
}

enum ContractStatus {
  DRAFT
  PENDING_GIVER_SIGNATURE
  PENDING_RECEIVER_SIGNATURE
  FULLY_SIGNED
  CANCELLED
  VOIDED
}

// Tracks all income events that feed the 20% management pool
model PoolTransaction {
  id                    String            @id @default(cuid())
  source_type           CommissionSource
  source_id             String            // Order ID, Membership ID, etc.
  source_description    String?

  total_amount_eur      BigInt            // Total income in cents
  pool_amount_eur       BigInt            // 20% of total_amount_eur

  period_month          Int               // 1-12
  period_year           Int
  
  status                PoolStatus        @default(PENDING)
  distributed_at        DateTime?
  created_at            DateTime          @default(now())

  earnings              PoolEarning[]

  @@index([source_type, source_id])
  @@index([period_year, period_month])
  @@index([status])
}

enum PoolStatus {
  PENDING
  DISTRIBUTED
  CANCELLED
}

// How much each General earned from a specific pool transaction
model PoolEarning {
  id                    String            @id @default(cuid())
  
  general_id            String
  general               General           @relation(fields: [general_id], references: [id])
  
  transaction_id        String
  transaction           PoolTransaction   @relation(fields: [transaction_id], references: [id])

  effective_percent     Float             // % applied at time of distribution
  amount_eur            BigInt            // In cents

  status                CommissionStatus  @default(PENDING)
  paid_at               DateTime?
  created_at            DateTime          @default(now())

  @@unique([general_id, transaction_id])
  @@index([general_id])
  @@index([transaction_id])
  @@index([status])
}

